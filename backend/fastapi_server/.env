# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kubochain:password@localhost:5433/kubochain

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=dev_secret_change_me_in_production_use_python3_secrets_token_hex_64
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# ── Twilio (OTP SMS) ───────────────────────────────────────────────────────────
# Leave blank in dev — OTP codes print to server console instead
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Firebase (FCM push notifications) ────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# ── CORS (comma-separated origins) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:8080

# ── OTP brute-force guard ─────────────────────────────────────────────────────
OTP_MAX_ATTEMPTS=5
