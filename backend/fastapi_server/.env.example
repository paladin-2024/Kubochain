# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kubochain:password@localhost:5432/kubochain

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_HEX_STRING
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# ── Twilio (OTP SMS) ───────────────────────────────────────────────────────────
# Leave blank in dev — OTP codes print to console instead
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Firebase (FCM push notifications) ────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# ── CORS (comma-separated origins) ───────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── OTP brute-force guard ─────────────────────────────────────────────────────
OTP_MAX_ATTEMPTS=5
