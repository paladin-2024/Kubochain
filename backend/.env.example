# Copy this to backend/.env and fill in real values before starting the server

# Database — used by docker-compose to set the postgres password
DB_PASSWORD=change_me_strong_password

# FastAPI app settings
JWT_SECRET=                        # python -c "import secrets; print(secrets.token_hex(32))"
ALLOWED_ORIGINS=http://your-domain-or-ip:8000

# Twilio OTP — leave blank to use dev bypass (code "000000")
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase push notifications — leave blank to disable
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Upload limits
MAX_UPLOAD_MB=5
